{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc-project-config-schema/refs/heads/main/schema.json",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eqeqeq": "error"
  },
  "overrides": [
    {
      "files": ["cli/src/lib/cli-output.ts", "cli/src/lib/logger.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    ".output/",
    "build/",
    "cli/sub-project/"
  ]
}
