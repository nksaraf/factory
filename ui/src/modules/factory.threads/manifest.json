{
  "id": "factory.threads",
  "displayName": "Factory Threads",
  "description": "AI agent threads, plans, and exchanges",
  "version": "0.0.1",
  "publisher": "factory",
  "engines": { "rio": ">=0.0.1" },
  "category": "platform",
  "tags": ["threads", "agents", "plans"],
  "categories": ["agents"],
  "main": "extension.ts",
  "module": {
    "sidebar": {
      "icon": "icon-[ph--chats-circle-duotone]",
      "label": "Threads",
      "order": 20
    },
    "routePrefix": "/threads"
  },
  "contributes": {
    "routes": [
      {
        "id": "factory.threads.route.home",
        "displayName": "Threads",
        "path": "/(root)/(app)/threads/"
      },
      {
        "id": "factory.threads.route.plans",
        "displayName": "Plans",
        "path": "/(root)/(app)/plans/"
      }
    ],
    "sidebarGroups": [
      {
        "id": "factory.threads.sidebar.group",
        "displayName": "Agents",
        "icon": "icon-[ph--robot-duotone]",
        "group": "Agents",
        "order": 20
      }
    ],
    "sidebarItems": [
      {
        "id": "factory.threads.sidebar.threads",
        "displayName": "Threads",
        "icon": "icon-[ph--chats-circle-duotone]",
        "href": "/threads",
        "group": "factory.threads.sidebar.group",
        "order": 1
      },
      {
        "id": "factory.threads.sidebar.plans",
        "displayName": "Plans",
        "icon": "icon-[ph--scroll-duotone]",
        "href": "/plans",
        "group": "factory.threads.sidebar.group",
        "order": 2
      }
    ],
    "layouts": [],
    "views": [],
    "panels": [],
    "commands": [],
    "layerRenderers": [],
    "toolbarItems": [],
    "menus": []
  },
  "activationEvents": ["onStart"]
}
