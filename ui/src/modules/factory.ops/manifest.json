        "path": "/(root)/(app)/ops/targets/:slug/"
      },
      {
        "id": "factory.ops.route.releases",
        "displayName": "Releases",
        "path": "/(root)/(app)/ops/releases/"
      },
      {
        "id": "factory.ops.route.rollouts",
        "displayName": "Rollouts",
        "path": "/(root)/(app)/ops/rollouts/"
