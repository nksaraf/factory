{
  "id": "factory.ops",
  "displayName": "Factory Ops",
  "description": "Sites, system deployments, workbenches, rollouts, interventions, and databases",
  "version": "0.0.2",
  "publisher": "factory",
  "engines": { "rio": ">=0.0.1" },
  "category": "platform",
  "tags": ["ops", "deployments", "sites", "workbenches"],
  "categories": ["operations"],
  "main": "extension.ts",
  "module": {
