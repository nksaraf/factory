{
  "id": "factory.ops",
  "displayName": "Factory Ops",
  "description": "Sites, deployments, releases, rollouts, and incidents",
  "version": "0.0.1",
  "publisher": "factory",
  "engines": { "rio": ">=0.0.1" },
  "category": "platform",
  "tags": ["ops", "deployments", "releases"],
  "categories": ["operations"],
  "main": "extension.ts",
