        "icon": "icon-[ph--hand-duotone]",
        "href": "/ops/interventions",
        "group": "factory.ops.sidebar.group",
        "order": 6
      },
      {
        "id": "factory.ops.sidebar.databases",
        "displayName": "Databases",
        "icon": "icon-[ph--database-duotone]",
        "href": "/ops/databases",
        "group": "factory.ops.sidebar.group",
        "order": 7
