{
  "id": "factory.fleet",
  "displayName": "Factory Fleet",
  "description": "Fleet management — sites, deployments, releases, incidents",
  "version": "0.0.1",
  "publisher": "factory",
  "engines": { "rio": ">=0.0.1" },
