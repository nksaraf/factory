{
  "name": "@rio.js/factory.ui",
  "version": "0.0.24",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=16384 vinxi build",
    "docker:build": "docker build -t asia-south2-docker.pkg.dev/rio-platform/docker/smart-market-app . --platform linux/amd64",
    "docker:push": "docker push asia-south2-docker.pkg.dev/rio-platform/docker/smart-market-app",
    "deploy": "pnpm run build && vercel deploy --prebuilt",
    "deploy:prod": "pnpm run build && vercel deploy --prebuilt --prod",
    "dev": "vinxi dev --host",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "run": "vinxi run",
    "registry-auth": "npx get-artifactregistry-token@3.4.2",
    "rio:update": "npx npm-check-updates @rio.js/* -u && pnpm install",
    "backend:up": "docker-compose up -d && pnpm exec vinxi run scripts/init.ts",
    "scheduler": "vinxi run scripts/scheduler.ts",
    "scheduler:manual": "vinxi run scripts/scheduler.ts --manual",
    "scheduler:daily": "vinxi run scripts/scheduler.ts --manual --daily",
    "scheduler:weekly": "vinxi run scripts/scheduler.ts --manual --weekly",
    "scheduler:monthly": "vinxi run scripts/scheduler.ts --manual --monthly",
    "scheduler:test": "CRON_SCHEDULE_DAILY='* * * * *' CRON_SCHEDULE_WEEKLY='* * * * *' CRON_SCHEDULE_MONTHLY='* * * * *' vinxi run scripts/scheduler.ts",
    "test:pdf-api": "vinxi run scripts/test-pdf-api.ts",
    "bull-board:dev": "vinxi run scripts/bull-board-server.ts",
    "bull-board": "vinxi run scripts/bull-board-server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi-ts": "openapi-ts",
    "openapi:fetch": "curl -s \"${OPENAPI_SPEC_URL:-http://localhost:8084/api/v1/data/openapi}\" -o openapi.json"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.29",
    "@aws-sdk/client-s3": "^3.954.0",
    "@aws-sdk/s3-request-presigner": "^3.943.0",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@mdx-js/react": "3.0.0",
    "@nivo/heatmap": "^0.88.0",
    "@rio.js/agents-ui": "workspace:*",
    "@rio.js/agents.core": "0.0.35",
    "@rio.js/app-ui": "workspace:0.0.28",
    "@rio.js/app.core": "workspace:*",
    "@rio.js/auth-client": "workspace:*",
    "@rio.js/auth-ui": "0.0.31",
    "@rio.js/auth.core": "workspace:*",
    "@rio.js/settings.organization": "workspace:*",
    "@rio.js/settings.user": "workspace:*",
    "@rio.js/client": "0.0.19",
    "@rio.js/color": "0.0.7",
    "@rio.js/datalake-ui": "workspace:*",
    "@rio.js/env": "0.0.8",
    "@rio.js/gdal": "0.0.26",
    "@rio.js/geo": "0.0.4",
    "@rio.js/gis": "0.0.32",
    "@rio.js/gis-ui": "0.0.27",
    "@rio.js/gis.core": "0.0.36",
    "@rio.js/gis.flows": "0.0.35",
    "@rio.js/gis.raster": "0.0.30",
    "@rio.js/maps-ui": "0.0.23",
    "@rio.js/table-ui": "0.0.20",
    "@rio.js/tunnel": "0.0.8",
    "@rio.js/ui": "0.0.32",
    "@rio.js/uikit": "0.0.20",
    "@rio.js/vinxi": "0.0.39",
    "@rio.js/workflows-ui": "0.0.35",
    "@rio.js/workspaces": "0.0.6",
    "@rio.js/workspaces-ui": "0.0.35",
    "@slack/web-api": "^7.13.0",
    "@stomp/stompjs": "^7.2.1",
    "@tanstack/react-query": "^5.87.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@xyflow/react": "12.3.1",
    "ai": "^6.0.87",
    "bullmq": "^5.67.2",
    "chroma-js": "^2.4.2",
    "date-fns": "^4.1.0",
    "dotenv": "16.4.5",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "fractional-indexing": "^3.2.0",
    "gdal-async": "^3.11.5",
    "ioredis": "^5.9.2",
    "lucide-react": "0.510.0",
    "match-sorter": "^8.0.1",
    "motion": "^12.27.2",
    "msw": "^2.12.7",
    "node-cron": "^4.2.1",
    "partysocket": "^1.1.10",
    "puppeteer": "^24.36.1",
    "react": "19.1.0",
    "react-compiler-runtime": "19.1.0-rc.1",
    "react-dom": "19.1.0",
    "react-gauge-chart": "^0.5.1",
    "react-markdown": "^10.1.0",
    "react-router": "7.11.0",
    "remark-gfm": "4.0.1",
    "resend": "4.0.1-alpha.0",
    "scule": "^1.3.0",
    "twilio": "^5.12.0",
    "vercel": "35.2.2",
    "vinxi": "0.5.11",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.1",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/ios": "^8.0.1",
    "@hey-api/openapi-ts": "0.93.1",
    "@iconify/json": "2.2.428",
    "@mdx-js/rollup": "3.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-web": "^0.51.0",
    "@opentelemetry/context-zone": "^2.1.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/instrumentation": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-web": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@playwright/test": "1.47.1",
    "@rio.js/tailwindcss3": "0.0.7",
    "@rio.js/workflows": "0.0.10",
    "@tailwindcss/typography": "^0.5.19",
    "@trivago/prettier-plugin-sort-imports": "5.2.2",
    "@types/express": "^5.0.6",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "@workflow/ai": "4.0.1-beta.32",
    "autoprefixer": "10.4.14",
    "prettier": "3.5.3",
    "rehype-pretty-code": "^0.14.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vite-plugin-node-polyfills": "0.22.0",
    "vitest": "^4.0.18"
  },
  "optimizeDependencies": {
    "include": [
      "@rio.js/gis.raster > @rio.js/deckgl-geotiff > jpeg-js"
    ],
    "exclude": [
      "@rio.js/env",
      "@rio.js/vinxi",
      "@rio.js/tailwindcss3",
      "@workflow/builders",
      "@rio.js/workflows",
      "@workflow/ai",
      "@workflow/utils",
      "gdal-async",
      "@better-auth/sso"
    ]
  },
  "pnpm": {
    "overrides": {
      "@iconify/json": "2.2.428",
      "apache-arrow": ">15",
      "vite": "npm:rolldown-vite@latest"
    }
  },
  "packageManager": "pnpm@9.15.4",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}