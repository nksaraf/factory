# Dev-only: run Vite dev server. Mount src/ and public/ as volumes for live reload.
# Usage: docker compose -f docker-compose.apps.yml -f docker-compose.dev.apps.yml up
# (docker-compose.dev.apps.yml mounts ./apps/control-plane-ui/src and ./apps/control-plane-ui/public)
FROM node:22-alpine

RUN apk update && apk add --no-cache \
    python3 \
    gdal \
    gdal-dev \
    build-base \
    && rm -rf /var/cache/apk/*

RUN corepack enable && corepack prepare pnpm@latest --activate

ENV GOOGLE_APPLICATION_CREDENTIALS_BASE64=""

WORKDIR /app

COPY package.json pnpm-lock.yaml* ./
COPY .npmrc* ./

RUN pnpm run registry-auth 2>/dev/null || true
RUN pnpm install --frozen-lockfile

# Config and entry; src and public are mounted at runtime
COPY . .

EXPOSE 3000
CMD ["pnpm", "dev", "--host", "0.0.0.0", "--port", "3000"]
