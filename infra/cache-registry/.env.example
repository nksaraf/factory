# Docker Hub credentials (free account — 200 pulls/6hr authenticated vs 100 anonymous)
DOCKERHUB_USERNAME=
DOCKERHUB_PASSWORD=

# GitHub Container Registry (personal access token with read:packages scope)
GHCR_USERNAME=
GHCR_TOKEN=

# GCP Service Account JSON (base64) — same as GOOGLE_APPLICATION_CREDENTIALS_BASE64
GCP_SA_JSON_BASE64=

# GCP npm token for Verdaccio uplink (generated via: npx get-artifactregistry-token)
GCP_NPM_TOKEN=
