{
  "name": "@smp/factory-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/factory.api.ts",
    "./app-type": "./src/app-type.ts",
    "./settings": "./src/settings.ts",
    "./logger": "./src/logger.ts",
    "./core": "./src/factory-core.ts",
    "./test-helpers": "./src/test-helpers.ts"
  },
  "scripts": {
    "dev": "bun x workflow build && bun --watch src/server.ts",
    "workflow:build": "bun x workflow build",
    "lint": "oxlint .",
    "typecheck": "! tsgo --noEmit 2>&1 | grep 'error TS'",
    "test": "pnpm run test:local",
    "test:local": "bun test --path-ignore-patterns='**/e2e-preview-lifecycle.test.ts' --path-ignore-patterns='**/tunnel-smoke.test.ts'",
    "test:full": "bun test",
    "test:smoke": "bun test src/__tests__/tunnel-smoke.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prepare": "effect-tsgo patch"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/google": "^3.0.29",
    "@anthropic-ai/sdk": "^0.80.0",
    "@chat-adapter/slack": "latest",
    "@chat-adapter/state-memory": "latest",
    "@chat-adapter/state-pg": "4.24.0",
    "@corsinvest/cv4pve-api-javascript": "^9.1.0",
    "@electric-sql/pglite": "^0.2.17",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/openapi": "^1.4.14",
    "@kubernetes/client-node": "^1.0.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-methods": "^6.0.0",
    "@rio.js/app-config": "0.3.0",
    "@slack/web-api": "^7.15.0",
    "@smp/factory-shared": "workspace:*",
    "@smp/graph": "workspace:*",
    "@workflow/ai": "4.0.1-beta.39",
    "@workflow/world-local": "4.1.0-beta.28",
    "@workflow/world-postgres": "4.1.0-beta.28",
    "ai": "^6.0.101",
    "chat": "latest",
    "cuid": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "effect": "3.21.1",
    "elysia": "^1.4.27",
    "jose": "^6.2.2",
    "lru-cache": "^11.2.7",
    "nats": "2.29.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "workflow": "4.0.1-beta.39",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@swc/core": "^1.11.0",
    "@types/bun": "^1.2.0",
    "@types/pg": "^8.18.0",
    "@workflow/swc-plugin": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "net-snmp": "^3.26.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@typescript/native-preview": "latest",
    "@effect/tsgo": "0.4.0"
  }
}
