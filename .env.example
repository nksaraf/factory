# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Secrets (resolved by dx sync)
GCP_NPM_SA_JSON_BASE64=secret:GOOGLE_APPLICATION_CREDENTIALS_BASE64
GOOGLE_APPLICATION_CREDENTIALS_BASE64=secret:GOOGLE_APPLICATION_CREDENTIALS_BASE64
CLICKSTACK_API_KEY=secret:CLICKSTACK_API_KEY
CLOUDFLARE_API_TOKEN=secret:CLOUDFLARE_API_TOKEN

# Optional API keys
SLACK_BOT_TOKEN=secret:SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=secret:SLACK_SIGNING_SECRET
ANTHROPIC_API_KEY=secret:ANTHROPIC_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=secret:GOOGLE_GENERATIVE_AI_API_KEY

# Local cache overrides for Docker registries
# Set when on the office network to use pull-through cache; leave unset in CI
# DOCKER_REGISTRY_GCP=docker-cache.internal:5003
# DOCKER_REGISTRY_GHCR=docker-cache.internal:5002
