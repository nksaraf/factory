      "@aws-sdk/credential-provider-web-identity": "3.972.18",
      "ioredis": "5.10.1",
      "@rio.js/app-ui": "0.0.30",
      "drizzle-orm": "0.45.1",
      "@electric-sql/pglite": "0.3.16",
      "@types/pg": "8.20.0",
      "@better-auth/utils": "0.3.1"
    }
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "lru-cache": "^11.2.7",
    "playwright": "^1.59.1"
  }
